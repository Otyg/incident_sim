{
  "$defs": {
    "Actor": {
      "type": "object",
      "title": "Actor",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "title": "Id",
          "description": "Stabilt unikt id för aktören, till exempel actor-ciso."
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "title": "Name",
          "description": "Visningsnamn för aktören."
        },
        "role": {
          "type": "string",
          "minLength": 2,
          "title": "Role",
          "description": "Kort beskrivning av aktörens ansvar eller funktion i övningen."
        }
      },
      "required": ["id", "name", "role"]
    },
    "Background": {
      "type": "object",
      "title": "Background",
      "properties": {
        "organization_type": {
          "type": "string",
          "minLength": 2,
          "title": "Organization Type",
          "description": "Typ av organisation som övningen utgår från, till exempel kommun eller myndighet."
        },
        "context": {
          "type": "string",
          "minLength": 3,
          "title": "Context",
          "description": "Bakgrundsbeskrivning som sätter scenen inför övningen."
        },
        "threat_actor": {
          "type": "string",
          "minLength": 2,
          "title": "Threat Actor",
          "description": "Kort beskrivning av aktören bakom hotet eller incidenten."
        },
        "assumptions": {
          "type": "array",
          "title": "Assumptions",
          "description": "Antaganden som gäller när scenariot startar, till exempel tekniska eller organisatoriska förutsättningar.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["organization_type", "context", "threat_actor"]
    },
    "NarratorInject": {
      "properties": {
        "type": {
          "enum": [
            "media",
            "executive",
            "operations",
            "technical",
            "stakeholder"
          ],
          "title": "Type",
          "type": "string"
        },
        "title": {
          "minLength": 2,
          "title": "Title",
          "type": "string"
        },
        "message": {
          "minLength": 3,
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "type",
        "title",
        "message"
      ],
      "title": "NarratorInject",
      "type": "object"
    },
    "NarratorResponse": {
      "properties": {
        "situation_update": {
          "minLength": 10,
          "title": "Situation Update",
          "type": "string"
        },
        "key_points": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 5,
          "minItems": 2,
          "title": "Key Points",
          "type": "array"
        },
        "new_consequences": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "New Consequences",
          "type": "array"
        },
        "injects": {
          "items": {
            "$ref": "#/$defs/NarratorInject"
          },
          "maxItems": 2,
          "title": "Injects",
          "type": "array"
        },
        "decisions_to_consider": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Decisions To Consider",
          "type": "array"
        },
        "facilitator_notes": {
          "minLength": 5,
          "title": "Facilitator Notes",
          "type": "string"
        }
      },
      "required": [
        "situation_update",
        "key_points",
        "facilitator_notes"
      ],
      "title": "NarratorResponse",
      "type": "object"
    },
    "InitialNarrationConfig": {
      "additionalProperties": false,
      "properties": {
        "default": {
          "$ref": "#/$defs/NarratorResponse",
          "description": "Gemensamt startnarrativ som används när ingen audience-specifik variant finns."
        },
        "by_audience": {
          "additionalProperties": {
            "$ref": "#/$defs/NarratorResponse"
          },
          "description": "Valfria audience-specifika startnarrativ som prioriteras före default.",
          "propertyNames": {
            "enum": [
              "krisledning",
              "it-ledning",
              "kommunikation"
            ]
          },
          "title": "By Audience",
          "type": "object"
        }
      },
      "anyOf": [
        {
          "required": [
            "default"
          ]
        },
        {
          "required": [
            "by_audience"
          ]
        }
      ],
      "title": "InitialNarrationConfig",
      "type": "object"
    },
    "InitialState": {
      "type": "object",
      "title": "InitialState",
      "properties": {
        "time": {
          "type": "string",
          "minLength": 4,
          "title": "Time",
          "description": "Starttid för scenariot, normalt i formatet HH:MM."
        },
        "phase": {
          "type": "string",
          "minLength": 2,
          "title": "Phase",
          "description": "Maskinläsbart namn på startfasen, till exempel initial-detection, containment eller recovery. Fasen används av den datadrivna scenariomotorn som initial aktiv fas."
        },
        "known_facts": {
          "type": "array",
          "title": "Known Facts",
          "description": "Det deltagarna känner till när övningen startar.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unknowns": {
          "type": "array",
          "title": "Unknowns",
          "description": "Viktiga osäkerheter som fortfarande behöver utredas.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "affected_systems": {
          "type": "array",
          "title": "Affected Systems",
          "description": "System eller tjänster som redan bedöms vara påverkade vid start.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "business_impact": {
          "type": "array",
          "title": "Business Impact",
          "description": "Beskrivning av verksamhetspåverkan i scenariots initiala läge.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "impact_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "title": "Impact Level"
        },
        "initial_narration": {
          "$ref": "#/$defs/InitialNarrationConfig",
          "description": "Fördefinierat startnarrativ för scenariot. Audience-specifika varianter prioriteras före default när sessionen startas."
        }
      },
      "required": [
        "time",
        "phase",
        "impact_level",
        "initial_narration"
      ]
    },
    "InjectDefinition": {
      "type": "object",
      "title": "InjectDefinition",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "title": "Id",
          "description": "Stabilt unikt id för injectet, till exempel inject-media-001."
        },
        "type": {
          "type": "string",
          "title": "Type",
          "enum": ["media", "executive", "operations", "technical", "stakeholder"],
          "description": "Vilken typ av inject det är, till exempel media eller operations."
        },
        "title": {
          "type": "string",
          "minLength": 2,
          "title": "Title",
          "description": "Kort rubrik för injectet."
        },
        "description": {
          "type": "string",
          "minLength": 3,
          "title": "Description",
          "description": "Beskrivning av vad injectet tillför till övningen."
        },
        "trigger_conditions": {
          "type": "array",
          "title": "Trigger Conditions",
          "description": "Mänskligt läsbara villkor eller signaler som beskriver när injectet är tänkt att användas. Dessa fält fungerar som dokumentation även när scenariot också har exekverbara regler.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "audience_relevance": {
          "type": "array",
          "title": "Audience Relevance",
          "description": "Vilka målgrupper injectet främst är relevant för.",
          "items": {
            "type": "string",
            "enum": ["krisledning", "it-ledning", "kommunikation"]
          }
        },
        "severity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "title": "Severity",
          "description": "Hur skarpt injectet är på en femgradig skala där 1 är låg störning och 5 är mycket kritiskt eller omedelbart handlingsdrivande."
        }
      },
      "required": ["id", "type", "title", "description", "severity"]
    },
    "RuleDefinition": {
      "type": "object",
      "title": "RuleDefinition",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "title": "Id",
          "description": "Stabilt unikt id för regeln, till exempel rule-escalation."
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "title": "Name",
          "description": "Kort namn på regeln."
        },
        "conditions": {
          "type": "array",
          "title": "Conditions",
          "description": "Mänskligt läsbara villkor för när regeln borde slå till. Fälten dokumenterar scenariots avsikt och exekveras inte generiskt av backend idag.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "effects": {
          "type": "array",
          "title": "Effects",
          "description": "Mänskligt läsbar beskrivning av regelns tänkta effekt i scenariot.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["id", "name"]
    },
    "PresentationGuideline": {
      "type": "object",
      "title": "PresentationGuideline",
      "properties": {
        "focus": {
          "type": "array",
          "title": "Focus",
          "description": "Vilka aspekter som bör betonas för målgruppen.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tone": {
          "type": "string",
          "minLength": 2,
          "title": "Tone",
          "description": "Vilken tonalitet eller nivå presentationen bör ha för målgruppen."
        }
      },
      "required": ["tone"]
    },
    "ExecutableRuleCondition": {
      "type": "object",
      "title": "ExecutableRuleCondition",
      "additionalProperties": false,
      "properties": {
        "fact": {
          "type": "string",
          "title": "Fact",
          "description": "Vilket state- eller actionfält som villkoret läser.",
          "enum": [
            "state.phase",
            "state.metrics.impact_level",
            "state.metrics.media_pressure",
            "state.metrics.service_disruption",
            "state.metrics.leadership_pressure",
            "state.metrics.public_confusion",
            "state.metrics.attack_surface",
            "state.flags.executive_escalation",
            "state.flags.external_comms_sent",
            "state.flags.forensic_analysis_started",
            "state.flags.external_access_restricted",
            "session.turn_number",
            "action.action_types",
            "action.targets"
          ]
        },
        "operator": {
          "type": "string",
          "title": "Operator",
          "description": "Vilken jämförelseoperator som ska användas.",
          "enum": ["equals", "not_equals", "gte", "lte", "contains", "not_contains"]
        },
        "value": {
          "title": "Value",
          "description": "Vilket värde villkoret jämför mot.",
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer" },
            { "type": "boolean" }
          ]
        }
      },
      "required": ["fact", "operator", "value"]
    },
    "ScenarioRuleEffect": {
      "type": "object",
      "title": "ScenarioRuleEffect",
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "set_phase" },
            "phase": {
              "type": "string",
              "minLength": 2,
              "description": "Ny fas för effekttypen set_phase."
            }
          },
          "required": ["type", "phase"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "add_active_inject" },
            "inject_id": {
              "type": "string",
              "minLength": 1,
              "description": "Inject-id som ska aktiveras."
            }
          },
          "required": ["type", "inject_id"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "resolve_inject" },
            "inject_id": {
              "type": "string",
              "minLength": 1,
              "description": "Inject-id som ska markeras som löst."
            }
          },
          "required": ["type", "inject_id"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "append_focus_item" },
            "item": {
              "type": "string",
              "minLength": 1,
              "description": "Textinnehåll för nytt fokusområde."
            }
          },
          "required": ["type", "item"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "append_consequence" },
            "item": {
              "type": "string",
              "minLength": 1,
              "description": "Textinnehåll för ny konsekvens."
            }
          },
          "required": ["type", "item"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "increment_metric" },
            "metric": {
              "type": "string",
              "description": "Vilket metricsfält som påverkas.",
              "enum": [
                "state.metrics.impact_level",
                "state.metrics.media_pressure",
                "state.metrics.service_disruption",
                "state.metrics.leadership_pressure",
                "state.metrics.public_confusion",
                "state.metrics.attack_surface"
              ]
            },
            "amount": {
              "type": "integer",
              "description": "Hur mycket metricsfältet ska ändras."
            }
          },
          "required": ["type", "metric", "amount"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "set_flag" },
            "flag": {
              "type": "string",
              "description": "Vilken flagga som ska sättas.",
              "enum": [
                "state.flags.executive_escalation",
                "state.flags.external_comms_sent",
                "state.flags.forensic_analysis_started",
                "state.flags.external_access_restricted"
              ]
            },
            "value": {
              "type": "boolean",
              "description": "Booleskt värde för flaggan."
            }
          },
          "required": ["type", "flag", "value"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "append_exercise_log" },
            "message": {
              "type": "string",
              "minLength": 1,
              "description": "Loggmeddelande att lägga till i sessionens övningslogg."
            },
            "log_type": {
              "type": "string",
              "minLength": 2,
              "description": "Valfri loggtyp för övningsloggen."
            }
          },
          "required": ["type", "message"]
        }
      ]
    },
    "ExecutableRule": {
      "type": "object",
      "title": "ExecutableRule",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "title": "Id",
          "description": "Stabilt unikt id för den exekverbara regeln."
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "title": "Name",
          "description": "Kort namn på den exekverbara regeln."
        },
        "trigger": {
          "type": "string",
          "title": "Trigger",
          "description": "Vilken händelse som ska utlösa regelutvärderingen.",
          "enum": ["session_started", "turn_processed"]
        },
        "conditions": {
          "type": "array",
          "title": "Conditions",
          "description": "Strukturerade villkor som alla måste vara uppfyllda för att regeln ska slå till.",
          "items": { "$ref": "#/$defs/ExecutableRuleCondition" }
        },
        "effects": {
          "type": "array",
          "title": "Effects",
          "description": "Deterministiska effekter som utförs när regeln träffar.",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ScenarioRuleEffect" }
        },
        "priority": {
          "type": "string",
          "title": "Priority",
          "description": "Prioritet för exekvering när flera regler matchar samma trigger.",
          "enum": ["low", "medium", "high"],
          "default": "medium"
        },
        "once": {
          "type": "boolean",
          "title": "Once",
          "description": "Om true får regeln bara appliceras en gång per session.",
          "default": false
        }
      },
      "required": ["id", "name", "trigger", "effects"]
    }
  },
  "type": "object",
  "title": "Scenario",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "title": "Id",
      "description": "Globalt unikt scenario-id som används vid lagring och hämtning."
    },
    "title": {
      "type": "string",
      "minLength": 2,
      "title": "Title",
      "description": "Scenarioets visningsnamn."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "title": "Version",
      "description": "Scenarioets versionsbeteckning, till exempel 1.0."
    },
    "description": {
      "type": "string",
      "minLength": 3,
      "title": "Description",
      "description": "Kort sammanfattning av scenarioets upplägg och kontext."
    },
    "audiences": {
      "type": "array",
      "title": "Audiences",
      "description": "Vilka målgrupper scenariot är avsett för.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["krisledning", "it-ledning", "kommunikation"]
      }
    },
    "training_goals": {
      "type": "array",
      "title": "Training Goals",
      "description": "Vilka förmågor eller lärandemål scenariot ska öva.",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "difficulty": {
      "type": "string",
      "title": "Difficulty",
      "description": "Övergripande svårighetsgrad för scenariot.",
      "enum": ["low", "medium", "high"]
    },
    "timebox_minutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 480,
      "title": "Timebox Minutes",
      "description": "Planerad maximal övningstid i minuter."
    },
    "background": {
      "$ref": "#/$defs/Background",
      "description": "Bakgrund och grundförutsättningar för scenariot."
    },
    "initial_state": {
      "$ref": "#/$defs/InitialState",
      "description": "Vilket läge övningen startar i."
    },
    "actors": {
      "type": "array",
      "title": "Actors",
      "description": "Viktiga aktörer eller roller i scenariot.",
      "items": { "$ref": "#/$defs/Actor" }
    },
    "inject_catalog": {
      "type": "array",
      "title": "Inject Catalog",
      "description": "Katalog över möjliga injects som kan användas under övningen.",
      "items": { "$ref": "#/$defs/InjectDefinition" }
    },
    "rules": {
      "type": "array",
      "title": "Rules",
      "description": "Dokumenterade scenarioregler och samband. Dessa legacyfält fungerar som författningsstöd men exekveras inte av den datadrivna scenariomotorn.",
      "items": { "$ref": "#/$defs/RuleDefinition" }
    },
    "executable_rules": {
      "type": "array",
      "title": "Executable Rules",
      "description": "Strukturerade och exekverbara scenarioregler för den datadrivna scenariomotorn.",
      "items": { "$ref": "#/$defs/ExecutableRule" }
    },
    "presentation_guidelines": {
      "type": "object",
      "title": "Presentation Guidelines",
      "description": "Hur scenariot bör presenteras för respektive målgrupp.",
      "propertyNames": {
        "enum": ["krisledning", "it-ledning", "kommunikation"]
      },
      "additionalProperties": {
        "$ref": "#/$defs/PresentationGuideline"
      }
    }
  },
  "required": [
    "id",
    "title",
    "version",
    "description",
    "audiences",
    "training_goals",
    "difficulty",
    "timebox_minutes",
    "background",
    "initial_state",
    "presentation_guidelines"
  ]
}
