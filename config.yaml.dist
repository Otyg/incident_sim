# Exempelkonfiguration för storage- och LLM-providerlager.
# Kopiera denna fil till `config.yaml` och justera värden efter din miljö.

storage:
  # Väljer vilken storage-backend applikationen ska använda.
  # Stödda värden just nu: `tinydb`, `in_memory`
  backend: tinydb

  tinydb:
    # Sökväg till JSON-filen där TinyDB lagrar scenarier, sessioner och tidslinje.
    path: data/incident_sim.json

logging:
  # Om detta fält utelämnas skrivs info till stdout och warning/error till stderr.
  # Sätt en fil för att skriva alla loggar till fil. Warning/error fortsätter då
  # även till stderr för att blockerande och hanterade fel ska synas direkt.
  file: null

llm_provider:
  # Väljer vilken runtime-provider som ska användas för interpretation och narration.
  # Stödda värden just nu: `ollama`, `openrouter`, `openai`
  provider: openrouter

  ollama:
    # Base URL för Ollama.
    # För högsta kvalitet i denna applikation rekommenderas Ollama Cloud.
    host: https://ollama.com

    # Standardmodell som används om inga mer specifika modellfält sätts.
    # qwen3.5:cloud är ett bra förstaval för svensk text, instruktioner och
    # strukturerad JSON-output.
    model: qwen3.5:cloud

    # Modell för att tolka deltagaråtgärder till strukturerad data.
    # Här används qwen3.5:cloud eftersom den är stark på instruction following,
    # språkhantering och schemaföljsam output.
    interpret_model: qwen3.5:cloud

    # Modell för att generera lägesbild och narration.
    # Här används glm-5:cloud separat eftersom den är ett starkt val för
    # resonemang och mer nyanserad narrativ återkoppling.
    narration_model: glm-5:cloud

    # Modell för scenarioförfattning från fri text till scenario-JSON.
    # Samma default som interpret_model fungerar bra när modellen är stark på
    # strukturerad output och schemaföljsamhet.
    scenario_model: qwen3.5:cloud

    # Promptfiler som används för respektive steg i Ollama-providerflödet.
    # Sökvägarna tolkas relativt `data/prompts/`.
    prompts:
      interpret: interpret_action.txt
      narration: generate_narration.txt
      debrief: generate_debrief.txt
      scenario_authoring: generate_scenario_draft.txt

    # API-nyckel för autentisering mot Ollama Cloud.
    api_key: YOUR_OLLAMA_API_KEY

  openai:
    # Bakåtkompatibelt alias för OpenRouterProvider.
    # Nya installationer bör använda `provider: openrouter` och blocket
    # `llm_provider.openrouter` i stället.
    api_key: null

    # Base URL för OpenRouters OpenAI-kompatibla API.
    base_url: https://openrouter.ai/api/v1

    # Modellnamn hos OpenRouter.
    model: null

  openrouter:
    # API-nyckel för OpenRouter.
    api_key: YOUR_OPENROUTER_API_KEY

    # Base URL för OpenRouters OpenAI-kompatibla API.
    base_url: https://openrouter.ai/api/v1

    # Standardmodell som används om inga mer specifika modellfält sätts.
    # Step 3.5 Flash (free) är ett bra gratis förstaval för narration,
    # debriefing och scenarioförfattning.
    model: stepfun/step-3.5-flash:free

    # Modell för att tolka deltagaråtgärder till strukturerad data.
    # GLM 4.5 Air (free) är ett starkt gratis förstaval för instruktioner,
    # strukturerad output och flerspråkiga texter.
    interpret_model: z-ai/glm-4.5-air:free

    # Modell för narration och lägesbild.
    narration_model: stepfun/step-3.5-flash:free

    # Modell för scenarioförfattning från fri text till scenario-JSON.
    scenario_model: stepfun/step-3.5-flash:free

    # Promptfiler som används för respektive steg.
    prompts:
      interpret: interpret_action.txt
      narration: generate_narration.txt
      debrief: generate_debrief.txt
      scenario_authoring: generate_scenario_draft.txt

    # Frivilliga OpenRouter-headers för rankning och identifiering av appen.
    app_url: https://example.com
    app_name: Incident Exercise Support

    # Timeout för HTTP-anrop i sekunder.
    timeout_seconds: 120
